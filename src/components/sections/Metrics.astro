---
// Metrics.astro - Animated counter metrics strip
---

<section
  id="metrics"
  aria-label="Key metrics"
  style="background: #0e0e16; border-top: 1px solid #1a1a28; border-bottom: 1px solid #1a1a28;"
>
  <div class="metrics-grid" role="list">

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="10"
        data-suffix="+"
        aria-live="polite"
      >0</span>
      <span class="metric-label">Years Experience</span>
    </div>

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="12"
        data-suffix=""
        aria-live="polite"
      >0</span>
      <span class="metric-label">Services Built</span>
    </div>

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="5"
        data-suffix="M+"
        aria-live="polite"
      >0</span>
      <span class="metric-label">Daily Active Users</span>
    </div>

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="5"
        data-suffix="+"
        aria-live="polite"
      >0</span>
      <span class="metric-label">Engineers Led</span>
    </div>

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="30"
        data-suffix="%"
        aria-live="polite"
      >0</span>
      <span class="metric-label">Infra Cost Reduction</span>
    </div>

    <div class="metric-item" role="listitem">
      <span
        class="metric-number"
        data-target="55"
        data-suffix="%"
        aria-live="polite"
      >0</span>
      <span class="metric-label">Build Time Saved</span>
    </div>

  </div>
</section>

<style>
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 2.25rem 1rem;
    border-right: 1px solid #1a1a28;
    text-align: center;
  }

  .metric-item:last-child {
    border-right: none;
  }

  @media (max-width: 640px) {
    .metric-item {
      border-right: none;
      border-bottom: 1px solid #1a1a28;
      padding: 1.75rem 1rem;
    }

    .metric-item:last-child {
      border-bottom: none;
    }
  }

  .metric-number {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #6c63ff 0%, #00d4aa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: #60607a;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.4;
    text-align: center;
  }
</style>

<script>
  const DURATION_MS = 1600;

  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCounter(el: HTMLElement): void {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const suffix = el.dataset.suffix ?? '';
    const startTime = performance.now();

    function tick(now: number): void {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / DURATION_MS, 1);
      const eased = easeOutCubic(progress);
      const current = Math.floor(eased * target);

      el.textContent = current + suffix;

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        el.textContent = target + suffix;
      }
    }

    requestAnimationFrame(tick);
  }

  const counters = document.querySelectorAll<HTMLElement>('.metric-number[data-target]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  counters.forEach((counter) => observer.observe(counter));
</script>
