---
import { experience } from '../../data/experience';
---

<section id="experience" aria-label="Professional Experience">
  <div class="sec-inner">

    <h2 class="sec-heading">Experience</h2>

    <ol class="exp-list" role="list">
      {experience.map((item) => (
        <li class={`exp-item reveal${item.type ? ' exp-item--dim' : ''}`}>
          <div class="exp-left">
            <span class="exp-period">{item.period}</span>
          </div>
          <div class="exp-right">
            <div class="exp-header">
              <span class="exp-title">{item.title}</span>
              <span class="exp-company">{item.company}</span>
              {item.location && <span class="exp-loc">{item.location}</span>}
            </div>
            {item.bullets && item.bullets.length > 0 && (
              <ul class="exp-bullets" role="list">
                {item.bullets.map(b => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>

<style>
  #experience {
    padding: 6rem max(2rem, 6vw);
    border-bottom: 1px solid var(--border);
  }

  .sec-inner {
    max-width: 52rem;
    margin: 0 auto;
  }

  .sec-heading {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--amber);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 3rem;
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0 2.5rem;
    padding: 1.75rem 0 1.75rem 0;
    border-top: 1px solid var(--border);
    border-left: 2px solid transparent;
    transition: border-color 0.2s, padding 0.2s;
  }

  .exp-item:hover {
    border-left-color: var(--amber);
    padding-left: 0.75rem;
  }

  .exp-item:last-child { border-bottom: 1px solid var(--border); }

  .exp-item--dim .exp-title,
  .exp-item--dim .exp-bullets li { color: var(--muted); }

  .exp-left { padding-top: 0.15rem; }

  .exp-period {
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .exp-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.75rem;
    margin-bottom: 0.75rem;
  }

  .exp-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .exp-company {
    font-size: 0.8rem;
    color: var(--amber);
  }

  .exp-loc {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .exp-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .exp-bullets li {
    font-size: 0.83rem;
    color: #888;
    line-height: 1.7;
    padding-left: 1rem;
    position: relative;
  }

  .exp-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--dim);
  }

  @media (max-width: 600px) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  /* reveal */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.in { opacity: 1; transform: none; }
</style>

<script>
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('#experience .reveal').forEach(el => io.observe(el));
</script>
